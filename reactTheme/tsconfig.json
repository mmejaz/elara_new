{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode — Vite handles emit, tsc only type-checks. */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Incremental migration — JS and TS coexist. */
    "allowJs": true,
    "checkJs": false,

    /* Strictness. Keep strictNullChecks; implicit `any` is still allowed while
       component internals are typed up incrementally, but unused code is now
       enforced to keep the tree clean. */
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Path alias: import from '@/...' → src/... */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
